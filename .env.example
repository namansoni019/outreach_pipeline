# ============================================================
# Outreach Pipeline -- Environment Variables
# ============================================================
# Copy this file to .env and fill in your API keys.
# In mock mode, keys are not required.
# ============================================================

# Ocean.io -- find similar companies
# Auth header: X-Api-Token
OCEAN_API_TOKEN=

# Prospeo -- find decision makers
# Auth header: X-KEY
PROSPEO_API_KEY=

# Eazyreach -- resolve verified emails from LinkedIn URLs
# Auth header: TBD (see docs.eazyreach.app)
EAZYREACH_API_KEY=

# Brevo -- send outreach emails
# Auth header: api-key
BREVO_API_KEY=

# Sender identity for outreach emails (used in template copy)
SENDER_EMAIL=you@yourdomain.com
SENDER_COMPANY=Your Company
SENDER_NAME=Your Name

# Sender identity for Brevo (actual from headers)
BREVO_SENDER_EMAIL=
BREVO_SENDER_NAME=
